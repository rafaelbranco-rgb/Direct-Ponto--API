# ───────── Servidor ─────────
PORT=3333
HOST=0.0.0.0
# Origens permitidas (CORS). Vazio = libera (rede interna). Em produção, liste as URLs internas:
# CORS_ORIGINS=http://192.168.0.10:5174,http://console.contato.local
CORS_ORIGINS=

# ───────── Segurança / JWT ─────────
JWT_SECRET=troque-por-um-segredo-bem-grande-e-aleatorio
JWT_EXPIRA_EM=12h

# ───────── PostgreSQL ─────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=contato
DB_PASS=contato
DB_NAME=contato
# Em dev cria/atualiza tabelas automaticamente. Em produção, use migrations e deixe false.
DB_SYNC=true
# true para bancos em nuvem que exigem SSL. Postgres local na VM = false.
DB_SSL=false

# ───────── Integração RM ─────────
# Com RM_FAKE=true o backend simula o RM (dev). Em produção, false + dados abaixo.
RM_FAKE=true

# Web service do RM (Consulta SQL) — funcionários/CPF (coligada 3 e 6).
# RM_CONSULTA_COD = código da Consulta SQL registrada no RM.
RM_API_URL=
RM_API_USER=
RM_API_PASS=
RM_CONSULTA_COD=
RM_COLIGADA=1
RM_SISTEMA=P

# n8n (gravar ajuste na folha / consultar ponto) — pode entrar depois.
N8N_TOKEN=
N8N_RM_PONTO_URL=
N8N_RM_AJUSTE_URL=

# ───────── Seed do supervisor inicial ─────────
SEED_ADMIN_EMAIL=admin@contato.local
SEED_ADMIN_SENHA=admin123
